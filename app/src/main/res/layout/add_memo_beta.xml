<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="지출"
        android:layout_marginStart="30dp"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textSize="15dp"
        />

    <Button
        android:id="@+id/income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/category"
        app:layout_constraintStart_toStartOf="@id/category"
        app:layout_constraintEnd_toStartOf="@id/expenses"
        android:layout_marginTop="15dp"
        android:text="수입"
        />

    <Button
        android:id="@+id/expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/income"
        app:layout_constraintTop_toTopOf="@id/income"
        android:layout_marginStart="10dp"
        android:text="지출"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="30dp"
        />

    <TextView
        android:id="@+id/dateTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/income"
        app:layout_constraintStart_toStartOf="@id/income"
        android:text="날짜"
        android:textSize="15dp"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/dateTextView"
        app:layout_constraintTop_toTopOf="@id/dateTextView"
        android:layout_marginStart="15dp"
        tools:text="2021_09_29"
        android:textStyle="bold"
        android:textSize="15dp"
        />

    <TextView
        android:id="@+id/time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/day"
        app:layout_constraintTop_toTopOf="@id/day"
        android:layout_marginStart="15dp"
        tools:text="오후 9:01"
        android:textStyle="bold"
        android:textSize="15dp"/>

    <TextView
        android:id="@+id/assetTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/dateTextView"
        app:layout_constraintStart_toStartOf="@id/dateTextView"
        android:layout_marginTop="15dp"
        android:textSize="15dp"
        android:textStyle="bold"
        android:text="자산"
        />

    <EditText
        android:id="@+id/asset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/assetTextView"
        app:layout_constraintStart_toEndOf="@id/assetTextView"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="@id/assetTextView"
        tools:text="용돈"
        android:textSize="15dp"
        android:textStyle="bold"
        android:maxLines="1"
        />

    <TextView
        android:id="@+id/attrTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/assetTextView"
        app:layout_constraintStart_toStartOf="@id/assetTextView"
        android:layout_marginTop="15dp"
        android:textSize="15dp"
        android:textStyle="bold"
        android:text="분류"
        />

    <EditText
        android:id="@+id/attr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/attrTextView"
        app:layout_constraintStart_toEndOf="@id/attrTextView"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="@id/attrTextView"
        tools:text="분류"
        android:textSize="15dp"
        android:textStyle="bold"
        android:maxLines="1"
        />

    <TextView
        android:id="@+id/priceTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/attrTextView"
        app:layout_constraintStart_toStartOf="@id/attrTextView"
        android:layout_marginTop="15dp"
        android:textSize="15dp"
        android:textStyle="bold"
        android:text="가격"
        />

    <EditText
        android:id="@+id/price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/priceTextView"
        app:layout_constraintStart_toEndOf="@id/priceTextView"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="@id/priceTextView"
        tools:text="가격"
        android:textSize="15dp"
        android:textStyle="bold"
        android:maxLines="1"
        />

    <TextView
        android:id="@+id/descriptionTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/priceTextView"
        app:layout_constraintStart_toStartOf="@id/priceTextView"
        android:layout_marginTop="15dp"
        android:textSize="15dp"
        android:textStyle="bold"
        android:text="내용"
        />

    <EditText
        android:id="@+id/description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/descriptionTextView"
        app:layout_constraintStart_toEndOf="@id/descriptionTextView"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="@id/descriptionTextView"
        tools:text="내용"
        android:textSize="15dp"
        android:textStyle="bold"
        android:maxLines="1"
        />

    <Button
        android:id="@+id/save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="저장하기"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="300dp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>